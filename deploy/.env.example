# Copy to deploy/.env and fill in. docker compose reads this automatically.

# Your domain. Point an A record (and AAAA if you have IPv6) at the host's IP.
# Caddy gets a TLS cert for this name automatically.
DOMAIN=cam.example.com

# Shared secrets — generate with: openssl rand -hex 32
# CAMERA_TOKEN goes in the Portal app; VIEWER_TOKEN goes in the browser viewer.
CAMERA_TOKEN=
VIEWER_TOKEN=

# TURN auth secret (coturn use-auth-secret). Generate with: openssl rand -hex 32
# The signaling server uses it to mint short-lived TURN credentials per client.
TURN_SECRET=

# How long minted TURN credentials stay valid (seconds).
TURN_TTL=86400

# Set true only after you wire a TLS cert into coturn (turns:5349). Default off;
# turn: over UDP/TCP 3478 works for most networks.
TURN_TLS=false

# Logical camera id.
CAMERA_ID=home

# STUN is fine to leave as the public default.
STUN_URL=stun:stun.l.google.com:19302

# Web Push (VAPID) — lets motion alerts reach viewers with no tab open.
# Generate with: npx web-push generate-vapid-keys
# Leave blank to disable push (live in-tab alerts still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
PUSH_COOLDOWN_MS=60000
