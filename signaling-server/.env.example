# Copy to .env and fill in. The server reads these at startup.

# Port for the HTTP + WebSocket server (also serves the web-client).
PORT=8080

# The Portal app authenticates with CAMERA_TOKEN. Use a long random string,
# e.g. `openssl rand -hex 32`.
CAMERA_TOKEN=change-me-camera

# --- Viewer authentication ---------------------------------------------------
# Per-viewer auth (recommended): set JWT_SECRET + ADMIN_PASSWORD to enable the
# admin console (/admin.html), invite links, revocation, and an audit log.
# Each viewer gets their own revocable identity instead of a shared secret.
JWT_SECRET=
ADMIN_PASSWORD=

# Legacy shared viewer token (optional). If set, browsers can also connect with
# this single shared secret. Leave BLANK once per-viewer auth is in use.
VIEWER_TOKEN=

# Enrollment is device-initiated: the Portal shows a single-use QR; the viewer
# scans it on the same Wi-Fi. The server requires the scanning phone to share the
# camera's public IP. Set false ONLY for testing across networks.
# ENROLL_SAME_NETWORK=true
# ENROLL_TTL=120        # QR / ticket lifetime, seconds

# Token lifetimes (seconds) — sensible defaults if unset:
# ACCESS_TTL=900        # 15 min  (the short-lived token sent over WebSocket)
# REFRESH_TTL=2592000   # 30 days (stored on the viewer's device)
# ADMIN_TTL=7200        # 2 hours

# Logical camera id (lets one server host more than one camera later).
CAMERA_ID=home

# --- NAT traversal -----------------------------------------------------------
# A public STUN server is enough for many home networks (and for local testing).
STUN_URL=stun:stun.l.google.com:19302

# For real remote access (viewer on cellular), run a TURN server. Two options:
#
# A) Ephemeral credentials (preferred) — used by the deploy/ docker stack.
#    Set TURN_HOST + TURN_SECRET and the server mints time-limited creds.
# TURN_HOST=cam.example.com
# TURN_SECRET=
# TURN_TTL=86400
# TURN_TLS=false
#
# B) Static credentials — point at any TURN server with a fixed user/pass.
# TURN_URL=
# TURN_USERNAME=
# TURN_CREDENTIAL=

# --- Web Push (VAPID) --------------------------------------------------------
# Delivers motion alerts to viewers even when no tab is open. Generate keys
# with: npx web-push generate-vapid-keys. Leave blank to disable push.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# PUSH_COOLDOWN_MS=60000
